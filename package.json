{
  "name": "terminal-shop",
  "version": "0.0.0",
  "sideEffects": false,
  "scripts": {
    "dev": "sst dev",
    "typecheck": "bun --filter=* typecheck",
    "sso": "aws sso login --sso-session=terminal --no-browser",
    "sdk": "sst shell ./packages/scripts/stainless",
    "cli": "cd ./packages/go && sst shell --stage=dev go run ./cmd/cli/main.go"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "linkedom": "0.18.6",
    "remeda": "2.3.0",
    "sst": "3.9.44"
  },
  "overrides": {
    "zod": "3.24.1",
    "@openauthjs/openauth": "0.4.3",
    "stripe": "15.2.0",
    "hono": "4.6.12"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  }
}
