---
import Layout from '@layouts/base.astro'
import ApiReference from '@components/api-reference'
import { dereference, load } from '@scalar/openapi-parser'
import { fetchUrls } from '@scalar/openapi-parser/plugins/fetch-urls'
import type { OpenAPIV3_1 } from '@scalar/openapi-types'

const openapiUrl = 'https://app.stainless.com/api/spec/documented/terminal'

// Fetch OpenAPI spec server-side
let schema: OpenAPIV3_1.Document | undefined = undefined
let specification: OpenAPIV3_1.Document | undefined = undefined

try {
  const { filesystem } = await load(openapiUrl, {
    plugins: [fetchUrls()],
  })
  const api = await dereference(filesystem)
  schema = api.schema as OpenAPIV3_1.Document
  specification = api.specification as OpenAPIV3_1.Document
} catch (error) {
  console.error('Error loading OpenAPI specification:', error)
  throw error
}

// Group endpoints by tag
let endpointsByTag: Record<
  string,
  {
    id: string
    path: string
    method: string
    operation: OpenAPIV3_1.OperationObject
  }[]
> = {}

if (schema) {
  const paths = schema.paths || {}

  Object.entries(paths).forEach(([path, pathItem]) => {
    if (!pathItem) return

    Object.entries(pathItem).forEach(([method, operation]) => {
      if (method === 'parameters') return // Skip parameters

      const tags: string[] = operation.tags || ['default']
      tags.forEach((tag) => {
        if (!endpointsByTag[tag]) {
          endpointsByTag[tag] = []
        }
        endpointsByTag[tag].push({
          id: operation.operationId,
          path,
          method,
          operation,
        })
      })
    })
  })

  // Sort each tag's endpoints by method priority: GET, PUT, POST, DELETE
  const methodPriority = { get: 1, put: 2, post: 3, delete: 4 }
  Object.keys(endpointsByTag).forEach((tag) => {
    endpointsByTag[tag].sort((a, b) => {
      const priorityA =
        methodPriority[a.method as keyof typeof methodPriority] || 999
      const priorityB =
        methodPriority[b.method as keyof typeof methodPriority] || 999
      return priorityA - priorityB
    })
  })
}

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=600, stale-while-revalidate=86400, stale-if-error=86400',
)

if (!schema?.info?.title) {
  throw new Error('OpenAPI spec not found')
}
---

<Layout>
  <div slot="docs">
    <ApiReference client:load {schema} {specification} {endpointsByTag} />
  </div>
</Layout>
