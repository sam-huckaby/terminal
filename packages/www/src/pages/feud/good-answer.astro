---
import Layout from '@layouts/base.astro'
import { Image } from 'astro:assets'
import header from '../../assets/feud-header.png'
import headerSmall from '../../assets/feud-header-small.png'
import Airtable from 'airtable'
import { Resource } from 'sst'

if (!Astro.locals.subject)
  return Astro.redirect('/auth/authorize?redirect=/feud/good-answer')

const AIRTABLE_BASE_ID = 'appb4HeMJeoeAGrQR'
const base = new Airtable({ apiKey: Resource.AirtableSecret.value }).base(
  AIRTABLE_BASE_ID,
)
const questions = base<{
  id: string
  text: string
}>('questions')
const answers = base<{
  id: string
  answer: string
  question: string[]
  userID: string
}>('answers')

// Handle form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const answer = formData.get('answer') as string
  const questionId = formData.get('questionId') as string
  await base<{
    userID: string
    question: string[]
    answer: string
  }>('answers').create([
    {
      fields: {
        answer,
        question: [questionId],
        userID: Astro.locals.subject?.properties?.userID || 'anonymous',
      },
    },
  ])

  // Post/Redirect/Get pattern to prevent resubmission on refresh
  return Astro.redirect('/feud/good-answer')
}

// Get user's previously answered questions
const userID = Astro.locals.subject?.properties?.userID || 'anonymous'
const userAnswers = await answers
  .select({
    filterByFormula: `{userID} = '${userID}'`,
  })
  .firstPage()

// Get all available questions
const allQuestions = await questions
  .select({
    maxRecords: 100,
    view: 'Grid view',
  })
  .firstPage()

// Get all the questions they've answered
const answeredQuestionIds = userAnswers
  .map((answer) => (answer.fields.question ? answer.fields.question[0] : ''))
  .filter(Boolean)

// Set maximum questions - either 10 or the total number of questions available
const MAX_QUESTIONS = Math.min(10, allQuestions.length)

// Current question number (1-based)
const currentQuestionNumber = userAnswers.length + 1

// Check if they've answered the maximum number of questions
if (userAnswers.length >= MAX_QUESTIONS) {
  return Astro.redirect('/feud/done')
}

// Filter out questions they've already answered
const unansweredQuestions = allQuestions.filter(
  (question) => !answeredQuestionIds.includes(question.id),
)

// Pick a random unanswered question or a random question if all have been answered
const randomQuestion =
  unansweredQuestions.length > 0
    ? unansweredQuestions[
        Math.floor(Math.random() * unansweredQuestions.length)
      ]
    : allQuestions[Math.floor(Math.random() * allQuestions.length)]
---

<Layout>
  <style>
    :global(body) {
      background-color: black;
    }
  </style>
  <div class="bg-black text-white h-screen flex flex-col">
    <div
      class="static top-0 flex justify-center items-center shrink-0 max-w-3xl mx-auto"
    >
      <Image src={header} alt="terminal feud" class="hidden sm:block" />
      <Image src={headerSmall} alt="terminal feud" class="sm:hidden" />
    </div>

    <div class="grow w-full max-w-md mx-auto relative p-6 font-mono">
      <div class="flex flex-col h-full">
        <h2 class="text-gray-8 px-4">
          {currentQuestionNumber}/{MAX_QUESTIONS}
        </h2>
        <p class="lowercase px-4">{randomQuestion.fields.text}</p>

        <form method="POST" class="mt-6 h-full flex flex-col justify-between">
          <input type="hidden" name="questionId" value={randomQuestion.id} />

          <input
            required
            autocomplete="off"
            type="text"
            name="answer"
            placeholder="answer"
            autofocus
            class="bg-white bg-opacity-[12%] py-2 px-4 text-[#B7B7B7] focus:bg-[#220B00] focus:ring-1 focus:ring-inset focus:ring-[#FF5C00] outline-none focus:outline-none"
          />

          <button
            type="submit"
            class="!h-[52px] bg-orange hover:enabled:bg-orange/80 text-white w-full lowercase flex items-center justify-center font-semibold text-xl mt-6"
          >
            next
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
