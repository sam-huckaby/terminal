---
import '@styles/global.css'
// import Banner from '@components/banner.astro'
import Button from '@components/button.astro'
import { Resource } from 'sst'
import TextJS from '../cui/components/textjs'

const title = 'wip: terminal (initial commit)'
const description =
  'Delicious Brazilian coffee, ethically sourced, and roasted to perfection • Order via your terminal • ssh terminal.shop'
const keywords = 'terminal, terminal shop'
const url = 'https://www.terminal.shop'
// const producthuntLink = undefined // TODO: add link

interface Props {
  light?: boolean
}

const links = [
  { href: '/cron', text: 'cron', active: false },
  { href: '/about', text: 'readme', active: false },
  // { href: '/docs', text: 'docs', active: false },
  // { href: '/api', text: 'api', active: false },
  { href: '/faq', text: 'faq', active: false },
]

let current = links.find(
  ({ href }) =>
    Astro.url.pathname === href || Astro.url.pathname === href + '/',
)
if (!current)
  current = links.find(({ href }) => Astro.url.pathname.startsWith(href))
if (current) current.active = true
---

<html lang="en" class="group">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content="https://www.terminal.shop/images/og.png"
    />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta
      property="twitter:image"
      content="https://www.terminal.shop/images/twitter.png"
    />
    <meta property="api-url" content={Resource.Api.url} />
    <meta property="auth-url" content={Resource.Auth.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <style>
      @font-face {
        font-family: 'geist';
        src:
          url('/fonts/geist-mono-latin.woff2') format('woff2-variations'),
          url('/fonts/geist-mono-latin.woff') format('woff-variations'),
          url('/fonts/geist-mono-latin.otf') format('opentype-variations');
        font-display: swap;
        font-style: normal;
        font-weight: 100 900;
      }
      @font-face {
        font-family: 'geist-fallback';
        src: local('Courier New');
        size-adjust: 100%;
        ascent-override: 97%;
        descent-override: 25%;
        line-gap-override: 1%;
      }
      @font-face {
        font-family: 'instrument';
        src:
          url('/fonts/instrument-serif.woff2') format('woff2'),
          url('/fonts/instrument-serif.ttf') format('truetype');
        font-display: swap;
        font-style: normal;
        font-weight: 400;
      }
      @font-face {
        font-family: 'instrument-fallback';
        src: local('Arial');
        ascent-override: 128.92%;
        descent-override: 40.37%;
        line-gap-override: 0%;
        size-adjust: 76.79%;
      }
    </style>
    <link
      rel="preload"
      href="/fonts/geist-mono-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/geist-mono-latin.woff"
      as="font"
      type="font/woff"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/geist-mono-latin.otf"
      as="font"
      type="font/otf"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/instrument-serif.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <script is:inline>
      function toggle(doc, banner) {
        const bannerState = localStorage.getItem(`${banner}-banner`)
        doc.documentElement.dataset[banner] = bannerState
      }

      toggle(document, 'producthunt')
      toggle(document, 'terminalhq')

      document.addEventListener('astro:before-swap', (ev) => {
        toggle(ev.newDocument, 'producthunt')
        toggle(ev.newDocument, 'terminalhq')
      })
    </script>
  </head>
  <body
    class:list={{
      'font-mono min-h-screen leading-normal tracking-normal text-pretty': true,
      'bg-black text-white selection:bg-gray-7': Astro.props.light !== true,
      'bg-cron-bg text-cron-text selection:bg-orange/80 selection:text-white':
        Astro.props.light === true,
      'flex flex-1 flex-col': true,
    }}
  >
    <!-- <Banner -->
    <!--   id="producthunt" -->
    <!--   class:list={{ -->
    <!--     'group-data-[producthunt=closed]:hidden': true, -->
    <!--     hidden: !producthuntLink, -->
    <!--   }} -->
    <!-- > -->
    <!--   we're live on -->
    <!--   <span class="flex gap-1 items-center"> -->
    <!--     <svg -->
    <!--       role="img" -->
    <!--       viewBox="0 0 24 24" -->
    <!--       xmlns="http://www.w3.org/2000/svg" -->
    <!--       class="w-4 h-4" -->
    <!--     > -->
    <!--       <title>Product Hunt</title> -->
    <!--       <path -->
    <!--         class="fill-current" -->
    <!--         d="M13.604 8.4h-3.405V12h3.405c.995 0 1.801-.806 1.801-1.801 0-.993-.805-1.799-1.801-1.799zM12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm1.604 14.4h-3.405V18H7.801V6h5.804c2.319 0 4.2 1.88 4.2 4.199 0 2.321-1.881 4.201-4.201 4.201z" -->
    <!--       > -->
    <!--       </path> -->
    <!--     </svg> -->
    <!--     <a href={producthuntLink} target="_blank" class="underline"> -->
    <!--       Product Hunt -->
    <!--     </a> -->
    <!--   </span> -->
    <!-- </Banner> -->
    <!-- <Banner -->
    <!--   id="terminalhq" -->
    <!--   class:list={{ 'group-data-[terminalhq=closed]:hidden': true }} -->
    <!-- > -->
    <!--   follow us -->
    <!--   <a -->
    <!--     href="https://x.com/terminaldotshop" -->
    <!--     target="_blank" -->
    <!--     class="focus:underline focus:outline-none" -->
    <!--   > -->
    <!--     @terminaldotshop -->
    <!--   </a> -->
    <!-- </Banner> -->
    <header
      class:list={{
        'h-10 border-b flex items-stretch sticky top-0 z-50': true,
        'bg-gray-1': Astro.props.light !== true,
        'bg-cron-header border-cron-border': Astro.props.light === true,
      }}
    >
      <a
        href="/"
        id="logo"
        class:list={{
          'relative px-6 border-r flex items-center text-[17px] tracking-[-0.15px] font-medium': true,
          'border-cron-border': Astro.props.light === true,
          '!text-white': !current && Astro.props.light !== true,
          '!text-gray-11': !!current && Astro.props.light !== true,
          'bg-cron-text bg-opacity-80': Astro.props.light === true,
          '[text-shadow:_2px_2px_3px_rgb(255_255_255_/_50%)] bg-clip-text !text-transparent':
            Astro.props.light === true,
        }}
      >
        {
          Astro.props.light && (
            <span class="absolute inset-0 flex items-center justify-center -z-10 [text-shadow:_0px_1px_0px_rgb(255_255_255_/_100%)]">
              terminal
            </span>
          )
        }
        terminal
      </a>
      <nav
        class:list={{
          'flex divide-x w-full overflow-x-auto overflow-y-hidden no-scrollbar': true,
          'divide-cron-border': Astro.props.light === true,
        }}
      >
        {
          links.map(({ href, text, active }) => (
            <Button
              disabled={active}
              href={active ? undefined : href}
              class:list={{
                'relative group/nav-item last:!border-r': true,
                '!text-white': active && Astro.props.light !== true,
                '!text-gray-11': !active && Astro.props.light !== true,
                '!bg-cron-text': Astro.props.light === true,
                '!bg-opacity-70': !active && Astro.props.light === true,
                '[text-shadow:_2px_2px_3px_rgb(255_255_255_/_50%)] bg-clip-text !text-transparent':
                  Astro.props.light === true,
              }}
            >
              <div
                class:list={{
                  'absolute inset-0 bg-cron-bgDark -z-50 hidden': true,
                  'group-hover/nav-item:block group-active/nav-item:brightness-[0.95]':
                    Astro.props.light,
                  '!block': Astro.props.light && active,
                }}
              />
              {Astro.props.light && (
                <div class="absolute left-0 inset-y-0 bg-white w-px" />
              )}
              {Astro.props.light && (
                <span class="absolute inset-0 flex items-center justify-center -z-10 [text-shadow:_0px_1px_0px_rgb(255_255_255_/_100%)]">
                  {text}
                </span>
              )}
              {text}
              {Astro.props.light && (
                <div class="hidden group-last/nav-item:last:block absolute -right-0.5 inset-y-0 bg-white w-px" />
              )}
            </Button>
          ))
        }
      </nav>
    </header>
    <slot name="docs" />
    {
      Astro.slots.has('docs') ? null : (
        <main class="relative my-20 grow max-w-xl">
          <slot />
        </main>
      )
    }
    <TextJS client:only="react" />
  </body>
</html>

